process {
    // Retry only on transient / scheduler / OOM-ish signals
    errorStrategy = {
        def r = [137, 143, 140, 138, 104]                 // retryable: OOM/kill/time/preempt/custom
        def f = [132, 133, 134, 135, 136, 139]            // fatal: code/logic bugs
        task.exitStatus in r ? 'retry' :
        task.exitStatus in f ? 'terminate'  : 'terminate'     // or 'ignore' if you prefer
    }
    maxRetries = 3
    maxErrors  = "-1"
}
